{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/cliente", "destination": "/clientes", "permanent": false },
    { "source": "/alunos", "destination": "/clientes", "permanent": false },
    { "source": "/admin", "destination": "/adm", "permanent": false }
  ],
  "rewrites": [
    { "source": "/admbar", "destination": "/adm" },
    { "source": "/admbar/:path*", "destination": "/adm" }
  ]
}
